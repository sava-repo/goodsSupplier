# ============================================================================
# Environment variables for goodsSupplier backend
# ============================================================================
# Copy this file to .env and adjust values for your environment.

# --- Application ---
# Environment: development | production
FLASK_ENV=development

# Host and port for `python run.py`
HOST=127.0.0.1
PORT=5000

# --- Database ---
# SQLite for development, PostgreSQL for production
DATABASE_URL=sqlite:///backend/dev.db
# Example for production:
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/goods_supplier

# --- Security ---
# JWT secret. REQUIRED in production. Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=dev-secret-do-not-use-in-prod

# JWT token lifetime in hours
JWT_ACCESS_TOKEN_HOURS=24

# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost:3000

# --- Password policy ---
# Minimum password length for new users
MIN_PASSWORD_LENGTH=8
